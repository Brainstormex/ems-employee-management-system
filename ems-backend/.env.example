# Server
NODE_ENV=development
PORT=4000

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://ems:ems_secret@localhost:5432/ems_db?schema=public

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars

# Access token: 15m, Refresh token: 7d (values used by auth in Phase 2)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin(s) allowed by CORS (comma-separated if multiple)
CORS_ORIGIN=http://localhost:3000

# Set to "true" in production / Render (HTTPS). Local http needs "false".
COOKIE_SECURE=false

# --- Production (Render) reminders ---
# NODE_ENV=production
# COOKIE_SECURE=true
# CORS_ORIGIN=https://your-frontend.vercel.app
# DATABASE_URL=<Render Postgres Internal URL>
# JWT_ACCESS_SECRET=<long random>
# JWT_REFRESH_SECRET=<long random>
